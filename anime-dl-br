def get_media_duration(filepath):
    """Get duration in seconds from media file via ffprobe."""
    try:
        result = subprocess.run(
            ["ffprobe", "-v", "quiet", "-print_format", "json",
             "-show_format", filepath],
            capture_output=True, text=True, timeout=30
        )
        if result.returncode == 0:
            info = json.loads(result.stdout)
            duration = float(info.get("format", {}).get("duration", 0))
            return max(1, int(duration))
    except Exception:
        pass
    return 1


def update_progress_db(anime_title, episode, filepath, mark_watched=False):
    """Update GoAnime's progress.db.

    Uses the production schema:
      allanime_id TEXT PRIMARY KEY,
      episode_number INTEGER, playback_time INTEGER DEFAULT 0,
      duration INTEGER, title TEXT, media_type TEXT DEFAULT 'anime',
      last_updated INTEGER

    Args:
        mark_watched: If True, sets playback_time = duration (episode fully watched).
                      If False, inserts new entry with playback_time=0 (just downloaded).
    """
    if not os.path.exists(GOANIME_DB):
        if mark_watched:
            print(f"  ℹ️  GoAnime DB not found: {GOANIME_DB}")
        return

    try:
        conn = sqlite3.connect(GOANIME_DB)
        cur = conn.cursor()

        allanime_id = f"{anime_title}-ep{episode}"
        now = int(time.time())

        if mark_watched:
            # Mark as fully watched: playback_time = duration
            cur.execute("""
                UPDATE media_progress
                SET playback_time = duration, last_updated = ?
                WHERE allanime_id = ?
            """, (now, allanime_id))
            if cur.rowcount > 0:
                conn.commit()
                print(f"  📝 Marked as watched ✓")
            else:
                # Entry doesn't exist yet — insert with watched status
                duration = get_media_duration(filepath)
                cur.execute(
                    """INSERT OR REPLACE INTO media_progress
                       (allanime_id, episode_number, playback_time, duration,
                        title, media_type, last_updated)
                       VALUES (?, ?, ?, ?, ?, 'anime', ?)""",
                    (allanime_id, episode, duration, duration, anime_title, now)
                )
                conn.commit()
                print(f"  📝 Added to tracking DB (watched, {duration}s)")
        else:
            # Download tracking: insert if not exists
            duration = get_media_duration(filepath)
            cur.execute(
                """INSERT OR IGNORE INTO media_progress
                   (allanime_id, episode_number, playback_time, duration,
                    title, media_type, last_updated)
                   VALUES (?, ?, 0, ?, ?, 'anime', ?)""",
                (allanime_id, episode, duration, anime_title, now)
            )
            if cur.rowcount > 0:
                conn.commit()
                print(f"  📝 Added to tracking DB ({duration}s)")

        conn.close()
    except Exception as e:
        print(f"  ⚠️  Could not update DB: {e}")


