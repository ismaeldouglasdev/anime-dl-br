# ── Slug Cache ──────────────────────────────────────────────────
_SLUG_CACHE = {}
_SLUG_CACHE_PATH = os.path.expanduser("~/.local/share/anime-dl-br/slug_cache.json")

def _load_slug_cache():
    global _SLUG_CACHE
    if _SLUG_CACHE:
        return
    try:
        if os.path.exists(_SLUG_CACHE_PATH):
            with open(_SLUG_CACHE_PATH) as f:
                _SLUG_CACHE = json.load(f)
    except (json.JSONDecodeError, OSError):
        _SLUG_CACHE = {}

def _save_slug_cache():
    try:
        os.makedirs(os.path.dirname(_SLUG_CACHE_PATH), exist_ok=True)
        with open(_SLUG_CACHE_PATH, "w") as f:
            json.dump(_SLUG_CACHE, f)
    except OSError:
        pass


def search_animefire(query):
    """Search anime on AnimeFire.

    AnimeFire's native search (?s=) is broken server-side — it ignores the
    query and always returns the same generic listing. This function tries
    it anyway, checks if results are relevant, and falls back to
    AnimesOnlineCC search if they aren't.

    Returns list of {slug, title, url, source}.
    """
    session = get_session()
    search_url = f"{ANIMEFIRE_BASE}/?s={quote(query)}"
    try:
        r = http_get(session, search_url)
    except Exception:
        return _search_animefire_fallback(query, session)

    if r.status_code != 200:
        return _search_animefire_fallback(query, session)

    html = r.text
    results = []
    seen = set()
    q_words = set(query.lower().split())

    # Collect ALL anime page slugs (skip episode pages /slug/N)
    for m in re.finditer(
        r'title=["\']([^"\']+)["\'][^>]*>.*?href=["\'](?:https://animefire\.io)?/animes/([^"\'/]+)["\']',
        html, re.IGNORECASE
    ):
        title = clean_title(m.group(1).strip())
        slug = m.group(2).rstrip('/')
        if slug in seen or not title or slug.endswith(('.webp', 'jpg', 'png')):
            continue
        seen.add(slug)
        results.append({
            "slug": slug,
            "title": title,
            "url": f"{ANIMEFIRE_BASE}/animes/{slug}",
            "source": "animefire",
        })

    # Also catch cards without title= attribute
    if not results:
        for m in re.finditer(
            r'<a\s+href=["\'](?:https://animefire\.io)?/animes/([^"\'/]+)["\'][^>]*>.*?<img[^>]*alt=["\']([^"\']+)["\']',
            html, re.DOTALL | re.IGNORECASE
        ):
            slug = m.group(1).rstrip('/')
            title = clean_title(m.group(2).strip())
            if slug not in seen and title and not slug.endswith('.webp'):
                seen.add(slug)
                snippet = html[m.start():m.end()]
                h3_m = re.search(r'<h3[^>]*class=["\']animeTitle["\'][^>]*>([^<]+)</h3>', snippet)
                if h3_m:
                    title = clean_title(h3_m.group(1).strip())
                results.append({
                    "slug": slug,
                    "title": title,
                    "url": f"{ANIMEFIRE_BASE}/animes/{slug}",
                    "source": "animefire",
                })

    # Check relevance — if none of the result titles contain the query words,
    # the search endpoint is returning garbage. Fall back.
    relevant = any(
        any(w in r["title"].lower() for w in q_words)
        for r in results
    ) if q_words else True

    if results and relevant:
        return results

    return _search_animefire_fallback(query, session)


def _search_animefire_fallback(query, session):
    """Fallback: search AnimesOnlineCC and try to resolve to AnimeFire slugs."""
    results = search_animesonline(query)
    for r in results:
        r["source"] = "animesonline"
        # Try to resolve to AnimeFire slug (cached)
        af_slug = _resolve_animefire_slug_cached(r["slug"])
        if af_slug:
            r["animefire_slug"] = af_slug
            r["animefire_url"] = f"{ANIMEFIRE_BASE}/animes/{af_slug}"
    return results


def _resolve_animefire_slug_cached(aonline_slug):
    """Resolve an AnimesOnlineCC slug to an AnimeFire slug with caching.

    AnimesOnlineCC slugs (e.g. 'jujutsu-kaisen-hd') differ from AnimeFire
    slugs (e.g. 'jujutsu-kaisen-tv-todos-os-episodios'). This function
    probes common AnimeFire URL patterns and caches the result so subsequent
    lookups are instant.
    """
    _load_slug_cache()

    base = re.sub(r'-(hd|dublado|legendado)$', '', aonline_slug)

    # Check cache
    if base in _SLUG_CACHE:
        return _SLUG_CACHE[base]

    session = get_session()
    patterns = [
        f"{base}-tv-todos-os-episodios",
        f"{base}-hd-todos-os-episodios",
        f"{base}-legendado-todos-os-episodios",
        f"{base}-tv",
        f"{base}-hd",
        f"{base}-todos-os-episodios",
        f"{base}-dublado-todos-os-episodios",
        f"{base}",
    ]

    # Try patterns in order, stop at first 200
    for pat in patterns:
        for url in [f"{ANIMEFIRE_BASE}/animes/{pat}",
                    f"{ANIMEFIRE_BASE}/animes/{pat}/"]:
            try:
                r = http_get(session, url, timeout=8)
                if r.status_code == 200:
                    _SLUG_CACHE[base] = pat
                    _save_slug_cache()
                    return pat
            except Exception:
                continue

    # Not found — cache None to avoid re-checking
    _SLUG_CACHE[base] = None
    _save_slug_cache()
    return None


def get_animefire_base_slug(slug):
    """Derive base slug for episode URLs from search-result slug.

    AnimeFire search returns slugs like 'jujutsu-kaisen-tv-todos-os-episodios'
    but episode links use 'jujutsu-kaisen-tv/{ep_num}'.
    """
    base = slug
    for suffix in ['-todos-os-episodios', '-dublado-todos-os-episodios',
                   '-hd-todos-os-episodios', '-legendado-todos-os-episodios']:
        if base.endswith(suffix):
            base = base[:-len(suffix)]
            break
    return base


def get_animefire_episodes(slug):
    """Get all episodes for an anime from AnimeFire.

    Returns dict with {title, episodes: [{num, url}], total_count}.
    """
    session = get_session()
    base_slug = get_animefire_base_slug(slug)

    # Try variants of the anime page URL
    urls_to_try = [
        f"{ANIMEFIRE_BASE}/animes/{slug}",
        f"{ANIMEFIRE_BASE}/animes/{base_slug}",
        f"{ANIMEFIRE_BASE}/animes/{slug}/",
        f"{ANIMEFIRE_BASE}/animes/{base_slug}/",
    ]

    html = None
    title = None
    used_base = base_slug

    for url in urls_to_try:
        try:
            r = http_get(session, url)
            if r.status_code == 200:
                html = r.text
                # Extract title — clean aggressively
                h1 = re.search(r'<h1[^>]*>([^<]+)</h1>', html)
                if h1:
                    title = h1.group(1).strip()
                    # Some pages return "Title - Episódio N" (episode page).
                    # Strip the episode suffix for clean anime title.
                    title = re.sub(
                        r'\s*[-–—|]\s*Epis[óo]dio\s+\d+.*$', '', title
                    ).strip()
                    title = re.sub(
                        r'\s*[-–—|]\s*Epis[óo]dio\s+[Úú]nico.*$', '', title
                    ).strip()
                if not title:
                    og = re.search(
                        r'<meta\s+property=["\']og:title["\'][^>]*content=["\']([^"\']+)["\']',
                        html
                    )
                    if og:
                        title = og.group(1).strip()
                        title = re.sub(
                            r'\s*[-–—|]\s*Epis[óo]dio\s+\d+.*$', '', title
                        ).strip()
                # Extract the actual base slug from episode links if different
                all_ep_slugs = set(re.findall(r'/animes/([^/]+)/\d+', html))
                if all_ep_slugs:
                    # Use the most common one
                    from collections import Counter
                    used_base = Counter(list(all_ep_slugs)).most_common(1)[0][0]
                break
        except Exception:
            continue

    if not html:
        return {"title": slug.replace('-', ' ').title(), "episodes": [], "total_count": 0}

    # Find episode links
    eps = []
    seen_nums = set()
    ep_pattern = rf'/animes/{re.escape(used_base)}/(\d+)'
    for m in re.finditer(ep_pattern, html):
        num = int(m.group(1))
        if num not in seen_nums:
            seen_nums.add(num)
            eps.append({
                "num": num,
                "url": f"{ANIMEFIRE_BASE}/animes/{used_base}/{num}",
            })

    eps.sort(key=lambda x: x["num"])
    return {
        "title": clean_title(title) if title else slug.replace('-', ' ').title(),
        "episodes": eps,
        "total_count": len(eps),
    }


def get_animefire_video_urls(base_slug, episode):
    """Get direct mp4 video URLs from AnimeFire's JSON video API.

    Returns list of {url, quality} sorted by quality descending.
    If the JSON API returns no videos but a Blogger embed exists,
    appends a marker {'blogger_url': '...'} for fallback handling.
    """
    session = get_session()
    ts = int(time.time())

    # Fetch episode page to find the video API endpoint
    ep_url = f"{ANIMEFIRE_BASE}/animes/{base_slug}/{episode}"
    try:
        r = http_get(session, ep_url)
    except Exception:
        return []
    if r.status_code != 200:
        return []

    html = r.text
    video_api_url = None

    # src="/video/{slug}/{ep}?tempsubs=0&..."
    for pat in [
        r'src=["\'](https://animefire\.io/video/[^"\']+)["\']',
        r'src=["\'](/video/[^"\']+)["\']',
        r'(?:href|data-src)=["\'](https://animefire\.io/video/[^"\']+)["\']',
    ]:
        m = re.search(pat, html)
        if m:
            raw = m.group(1)
            video_api_url = raw if raw.startswith('http') else f"{ANIMEFIRE_BASE}{raw}"
            break

    # Construct directly if not found
    if not video_api_url:
        video_api_url = f"{ANIMEFIRE_BASE}/video/{base_slug}/{episode}?tempsubs=0&{ts}"

    # Fetch the JSON video API
    try:
        r2 = http_get(session, video_api_url)
    except Exception:
        return []
    if r2.status_code != 200:
        return []

    try:
        data = r2.json()
    except (json.JSONDecodeError, ValueError):
        return []

    videos = []
    for item in data.get("data", []):
        src = item.get("src", "")
        label = item.get("label", "unknown")
        if src and src.startswith("http"):
            videos.append({"url": src, "quality": label})

    # Sort: 1080p > 720p > 480p > 360p > unknown
    quality_order = {"1080p": 3, "720p": 2, "480p": 1, "360p": 0}
    videos.sort(key=lambda v: quality_order.get(v["quality"], -1), reverse=True)

    # If API returned empty but page has a Blogger embed, mark for fallback
    if not videos:
        blogger_urls = re.findall(
            r'src=["\'](https://www\.blogger\.com/video\.g\?token=[^"\']+)["\']', html
        )
        if blogger_urls:
            videos.append({"blogger_url": blogger_urls[0]})

    return videos


# ── Playwright Blogger Extraction ─────────────────────────────────
def get_blogger_video_url_playwright(episode_url, timeout=30):
    """Extract direct video URL from an AnimesOnlineCC episode page using Playwright.

    AnimesOnlineCC episodes use Blogger's iframe player which loads video via
    Google's internal batch-execute RPC API. The video URL only appears when
    the full episode page loads the Blogger iframe with the correct referrer
    context — navigating to the Blogger URL directly gives an auth wall.

    This function navigates to the episode page, intercepts the batch-execute
    RPC response, and extracts the googlevideo URL.

    Returns (video_url, quality_label) tuple or (None, None).
    """
    if not HAS_PLAYWRIGHT:
        return None, None

    import urllib.parse
    import json

    try:
        with sync_playwright() as p:
            browser = p.chromium.launch(
                headless=True,
                args=["--no-sandbox", "--disable-setuid-sandbox"]
            )
            context = browser.new_context(
                user_agent=USER_AGENT,
                locale="pt-BR",
                viewport={"width": 1280, "height": 720},
            )
            page = context.new_page()
            captured_url = None
            captured_quality = None

            def _on_response(response):
                nonlocal captured_url, captured_quality
                if captured_url:
                    return

                url = response.url

                # Intercept Blogger's batch execute RPC
                if "batchexecute" in url:
                    try:
                        body = response.body()
                        text = body.decode("utf-8", errors="replace")
                        # The response format is: )]}'\n\nNUMBER\n[["wrb.fr","WcwnYd","[...video URLs...]",...]
                        # URLs are googlevideo CDN URLs with subdomain, e.g.:
                        #   https://rr1---sn-8p8v-bg067.googlevideo.com/videoplayback?...
                        m = re.search(r'https?://[^"\s]*googlevideo\.com[^"\s]+', text)
                        if m:
                            raw = m.group(0)
                            # Unescape \\u003d → = and \\u0026 → &
                            raw = raw.replace("\\\\u003d", "=").replace("\\\\u0026", "&")
                            raw = raw.replace("\\u003d", "=").replace("\\u0026", "&")
                            full_url = raw
                            # Prefer itag=22 (720p) over itag=18 (360p)
                            if "itag=22" in full_url:
                                captured_url = full_url
                                captured_quality = "720p"
                            elif "itag=18" in full_url and not captured_url:
                                captured_url = full_url
                                captured_quality = "360p"
                    except Exception:
                        pass

                # Fallback: direct video response capture
                ct = response.headers.get("content-type", "")
                if ct.startswith("video/"):
                    captured_url = response.url
                    captured_quality = "unknown"

            page.on("response", _on_response)

            try:
                page.goto(episode_url, wait_until="domcontentloaded", timeout=timeout * 1000)
                # Wait for Blogger JS to load and execute batch RPC
                page.wait_for_timeout(10000)
            except Exception:
                pass
            finally:
                browser.close()

            if captured_url:
                return captured_url, captured_quality

            return None, None
    except Exception:
        return None, None


# ── Shared Download Helper ────────────────────────────────────────
def _download_video(video_url, out_path, out_dir, plex_name, embed_subs=False, referer=None):
    """Download a video URL using yt-dlp (preferred) or requests (fallback).

    Returns path to downloaded file or None.
    """
    # Method 1: yt-dlp (handles resume, progress, retries)
    if YT_DLP_BIN and shutil.which(YT_DLP_BIN):
        ytdl_cmd = [YT_DLP_BIN, "--no-warnings", "--output", out_path,
                    "--referer", referer or "",
                    "--user-agent", USER_AGENT]
        if 'googlevideo' in video_url.lower():
            ytdl_cmd += ["--no-check-certificate"]
        if embed_subs:
            ytdl_cmd += ["--embed-subs", "--embed-metadata"]
            ytdl_cmd += ["--sub-langs", "all"]
        ytdl_cmd += [video_url]
        try:
            result = subprocess.run(
                ytdl_cmd,
                capture_output=True, text=True, timeout=600
            )
            if result.returncode == 0 and os.path.isfile(out_path) and os.path.getsize(out_path) > 0:
                size_mb = os.path.getsize(out_path) / (1024 * 1024)
                print(f"  ✅ Complete: {size_mb:.1f} MB")
                return out_path

            # yt-dlp may append suffixes — check for partial files
            try:
                for f in os.listdir(out_dir):
                    fpath = os.path.join(out_dir, f)
                    base_no_ext = os.path.splitext(plex_name)[0]
                    if f.startswith(base_no_ext) and f.endswith(('.mp4', '.mkv', '.webm')):
                        if f != plex_name:
                            os.rename(fpath, out_path)
                        return out_path
            except OSError:
                pass
        except (subprocess.TimeoutExpired, OSError) as e:
            print(f"  ⚠️  yt-dlp: {e}")

    # Method 2: Direct download with requests
    print(f"  📥 Downloading (requests)...")
    sess = get_session()
    try:
        kwargs = {"stream": True, "timeout": 120}
        if 'googlevideo' in video_url.lower():
            kwargs["verify"] = False
        kwargs["headers"] = {"Referer": referer} if referer else {}
        video_r = http_get(sess, video_url, **kwargs)
        video_r.raise_for_status()

        total = int(video_r.headers.get('content-length', 0))
        downloaded = 0

        with open(out_path, 'wb') as f:
            for chunk in video_r.iter_content(chunk_size=8192):
                if chunk:
                    f.write(chunk)
                    downloaded += len(chunk)
                    if total > 0:
                        pct = downloaded / total * 100
                        bar_len = 30
                        filled = int(bar_len * downloaded / total)
                        bar = '█' * filled + '░' * (bar_len - filled)
                        sys.stdout.write(f"\r    [{bar}] {pct:.0f}%")
                        sys.stdout.flush()
        print()

        if os.path.isfile(out_path) and os.path.getsize(out_path) > 0:
            size_mb = os.path.getsize(out_path) / (1024 * 1024)
            print(f"  ✅ Complete: {size_mb:.1f} MB")
            return out_path
    except Exception as e:
        print(f"  ❌ Download failed: {e}")
        if os.path.isfile(out_path):
            os.remove(out_path)

    return None


def download_via_goanime(anime_title, episode, quality="best", output_dir=None):
    """Attempt download using goanime binary. Returns file path or None."""
    if not os.path.isfile(GOANIME_BIN):
        return None

    try:
        cmd = [GOANIME_BIN, "-d", "--source", "animefire", "--quality", quality]
        if output_dir:
            cmd += ["-o", output_dir]
        cmd += [anime_title, str(episode)]

        result = subprocess.run(
            cmd, capture_output=True, text=True, timeout=300
        )

        # Check success
        if result.returncode == 0 and "ERRO" not in result.stderr:
            out_dir = output_dir or DEFAULT_DOWNLOAD_DIR
            # Find most recent file in output dir
            if os.path.isdir(out_dir):
                files = [os.path.join(out_dir, f) for f in os.listdir(out_dir)
                        if f.endswith(('.mp4', '.mkv'))]
                if files:
                    newest = max(files, key=os.path.getmtime)
                    if time.time() - os.path.getmtime(newest) < 60:
                        return newest
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        pass

    return None


def download_animefire(anime_title, slug, episode, quality="best", output_dir=None, embed_subs=False):
    """Download a single episode from AnimeFire.

    Tries goanime first, falls back to AnimeFire's JSON video API.
    Returns path to downloaded file or None.
    """
    base_slug = get_animefire_base_slug(slug)
    out_dir = output_dir or DEFAULT_DOWNLOAD_DIR
    os.makedirs(out_dir, exist_ok=True)

    # Plex-compatible filename
    plex_name = f"{anime_title} - S01E{episode:02d}.mp4"
    out_path = os.path.join(out_dir, plex_name)

    if os.path.isfile(out_path):
        print(f"  ⏭️  Already exists: {out_path}")
        return out_path

    # Method 1: Try goanime binary
    goanime_path = download_via_goanime(anime_title, episode, quality, output_dir)
    if goanime_path and os.path.isfile(goanime_path):
        goanime_base = os.path.basename(goanime_path)
        if goanime_base != plex_name:
            # Rename to Plex format
            if os.path.isfile(out_path):
                os.remove(out_path)
            try:
                os.rename(goanime_path, out_path)
            except OSError:
                shutil.copy2(goanime_path, out_path)
                os.remove(goanime_path)
        return out_path

    # Method 2: Direct AnimeFire JSON API download
    print(f"  🅰️  Fetching video URLs from AnimeFire...")
    videos = get_animefire_video_urls(base_slug, episode)

    if not videos:
        print(f"  ❌ No video URLs found for episode {episode}")
        return None

    # Check if the result is a Blogger fallback marker
    if "blogger_url" in videos[0]:
        b_url = videos[0]["blogger_url"]
        print(f"  ℹ️  This episode is hosted on Blogger (JS player).")

        # Method A: Try Playwright extraction (browser-based)
        if HAS_PLAYWRIGHT:
            print(f"  🎭 Attempting Playwright extraction...")
            animefire_ep_url = f"{ANIMEFIRE_BASE}/animes/{base_slug}/{episode}"
            pw_url, pw_q = get_blogger_video_url_playwright(animefire_ep_url)
            if pw_url:
                print(f"  ✅ Playwright extracted video URL ({pw_q or 'unknown'})")
                return _download_video(pw_url, out_path, out_dir, plex_name, embed_subs, f"{ANIMEFIRE_BASE}/")

        # Method B: Try AnimesOnlineCC as fallback
        print(f"  🔄 Trying AnimesOnlineCC as fallback...")
        aonline_path = download_animesonline(anime_title, slug, episode, quality, output_dir)
        if aonline_path:
            return aonline_path
        print(f"  ❌ Could not extract video from Blogger or AnimesOnlineCC.")
        print(f"  💡 Try: anime-dl-br episodes {slug} --source animesonline")
        return None

    # Select quality
    quality_map = {"1080p": 3, "720p": 2, "480p": 1, "360p": 0, "best": 2}
    target = quality_map.get(quality, 2)

    selected = None
    for v in videos:
        vq = quality_map.get(v["quality"], -1)
        if vq <= target:
            selected = v
            break
    if not selected:
        selected = videos[0]

    video_url = selected["url"]
    print(f"  📥 Downloading {selected['quality']}: {video_url[:80]}...")
    return _download_video(video_url, out_path, out_dir, plex_name, embed_subs, f"{ANIMEFIRE_BASE}/")


