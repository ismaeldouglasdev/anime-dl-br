MPV_BIN = shutil.which("mpv") or "/usr/bin/mpv"


def cmd_watch(title, episode=None, player=None, download_dir=None):
    """Find and play a downloaded episode.

    If episode is None, list available downloads and let user pick.
    Returns True if played successfully.
    """
    ddir = download_dir or DEFAULT_DOWNLOAD_DIR
    if not os.path.isdir(ddir):
        print(f"📁 Download directory not found: {ddir}")
        print(f"   Download an episode first: anime-dl-br download \"{title}\" 1")
        return False

    files = sorted(os.listdir(ddir))
    title_norm = title.lower().replace(' ', '-').replace(':', '').replace('(', '').replace(')', '')

    if episode is not None:
        ep_str = f"{episode:02d}"
        # Match by normalized filename containing title + episode number
        matched = []
        for f in files:
            if not f.endswith(('.mp4', '.mkv')):
                continue
            fnorm = f.lower().replace(' ', '-').replace(':', '').replace('(', '').replace(')', '')
            if title_norm in fnorm:
                # Check for episode match: S01E01, -01, _01, etc.
                if re.search(rf'(?:S\d+E)?0*{episode}(?:\.mp4|\.mkv|\b)', fnorm):
                    matched.append(f)

        if not matched:
            print(f"❌ Episode {episode} of '{title}' not found.")
            print(f"   Directory: {ddir}")
            print(f"   Download it first: anime-dl-br download \"{title}\" {episode}")
            return False

        filepath = os.path.join(ddir, matched[0])
    else:
        # List all files matching the title
        title_norm = title.lower().replace(' ', '-').replace(':', '')
        candidates = [f for f in files
                      if f.endswith(('.mp4', '.mkv')) and title_norm in f.lower()]
        if not candidates:
            print(f"❌ No downloaded episodes found for '{title}'.")
            print(f"   Directory: {ddir}")
            print(f"   Available downloads:")
            for f in files[:10]:
                if f.endswith(('.mp4', '.mkv')):
                    print(f"     {f}")
            return False

        if len(candidates) == 1:
            filepath = os.path.join(ddir, candidates[0])
        else:
            # Show list and let user pick
            print(f"\n📺 Downloaded episodes of '{title}':\n")
            for i, f in enumerate(candidates, 1):
                size_mb = os.path.getsize(os.path.join(ddir, f)) / (1024 * 1024)
                print(f"  {i}. {f} ({size_mb:.0f} MB)")
            print()
            try:
                choice = input(f"  Choose episode (1-{len(candidates)}, Enter=1): ").strip()
                idx = int(choice) - 1 if choice else 0
                if idx < 0 or idx >= len(candidates):
                    print("Invalid choice.")
                    return False
            except (ValueError, EOFError):
                idx = 0
            filepath = os.path.join(ddir, candidates[idx])

    if not os.path.isfile(filepath):
        print(f"❌ File not found: {filepath}")
        return False

    size_mb = os.path.getsize(filepath) / (1024 * 1024)
    print(f"\n▶️  Playing: {os.path.basename(filepath)} ({size_mb:.0f} MB)")
    print(f"   Player: {player or MPV_BIN}\n")

    try:
        player_bin = player or MPV_BIN
        proc = subprocess.run([player_bin, filepath],
                              stdin=sys.stdin, stdout=sys.stdout, stderr=sys.stderr)
        exit_code = proc.returncode
    except FileNotFoundError:
        print(f"❌ Player not found: {player or MPV_BIN}")
        print(f"   Install mpv: sudo apt install mpv")
        return False
    except Exception as e:
        print(f"❌ Failed to play: {e}")
        return False

    # After playback, ask to mark as watched
    print(f"\n✅ Playback finished (exit code: {exit_code})")
    try:
        resp = input(f"  Mark as watched? [Y/n]: ").strip().lower()
        if resp in ('', 'y', 'yes', 's', 'sim'):
            # Extract episode number for DB update
            ep_num = episode
            if ep_num is None:
                ep_m = re.search(r'S\d+E(\d+)', filepath)
                if ep_m:
                    ep_num = int(ep_m.group(1))
                else:
                    ep_m = re.search(r'(\d+)', os.path.basename(filepath).replace('-', ' '))
                    ep_num = int(ep_m.group(1)) if ep_m else 0
            update_progress_db(title, ep_num, filepath, mark_watched=True)
    except (EOFError, KeyboardInterrupt):
        pass

    return True


