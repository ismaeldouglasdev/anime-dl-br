def search_animesonline(query):
    """Search anime on AnimesOnlineCC. Returns list of {slug, title, url}."""
    session = get_session()
    search_url = f"{ANIMESONLINE_BASE}/?s={quote(query)}"
    try:
        r = http_get(session, search_url)
    except Exception:
        return []
    if r.status_code != 200:
        return []

    html = r.text
    results = []
    seen = set()

    # <a href="https://animesonlinecc.to/anime/{slug}/">
    for m in re.finditer(
        r'<a\s+href=["\']https://animesonlinecc\.to/anime/([^"\']+)/?["\'][^>]*>(.*?)</a>',
        html, re.DOTALL | re.IGNORECASE
    ):
        slug = m.group(1).rstrip('/')
        inner = m.group(2)
        # Extract title from img alt or text
        alt_m = re.search(r'alt=["\']([^"\']+)["\']', inner)
        title = alt_m.group(1).strip() if alt_m else ''
        if not title:
            title = re.sub(r'<[^>]+>', '', inner).strip()
            if slug not in seen and title.strip() and slug:
                seen.add(slug)
                results.append({
                    "slug": slug,
                    "title": clean_title(title.strip()),
                    "url": f"{ANIMESONLINE_BASE}/anime/{slug}/",
                })

    return results


def get_animesonline_episodes(slug):
    """Get all episodes for an anime on AnimesOnlineCC.

    Returns dict with {title, episodes: [{num, url}], total_count}.
    """
    session = get_session()
    url = f"{ANIMESONLINE_BASE}/anime/{slug}/"
    try:
        r = http_get(session, url)
    except Exception:
        return {"title": slug.replace('-', ' ').title(), "episodes": [], "total_count": 0}
    if r.status_code != 200:
        return {"title": slug.replace('-', ' ').title(), "episodes": [], "total_count": 0}

    html = r.text

    # Extract title
    title = None
    h1 = re.search(r'<h1[^>]*>([^<]+)</h1>', html)
    if h1:
        title = h1.group(1).strip()
    if not title:
        og = re.search(
            r'<meta\s+property=["\']og:title["\'][^>]*content=["\']([^"\']+)["\']', html
        )
        if og:
            title = og.group(1).strip()
    if not title:
        title = slug.replace('-', ' ').title()

    # Find episode links
    eps = []
    seen_nums = set()
    for m in re.finditer(
        r'href=["\'](https://animesonlinecc\.to/episodio/[^"\']*?-(\d+)/?)["\']',
        html, re.IGNORECASE
    ):
        href = m.group(1)
        num = int(m.group(2))
        if num not in seen_nums:
            seen_nums.add(num)
            eps.append({"num": num, "url": href})

    eps.sort(key=lambda x: x["num"])
    return {"title": clean_title(title) if title else slug.replace('-', ' ').title(),
            "episodes": eps, "total_count": len(eps)}


def get_animesonline_video_url(slug, episode):
    """Extract direct video URL from an AnimesOnlineCC episode page.

    Returns video URL string or None.
    """
    base_name = re.sub(r'-hd$', '', slug)
    ep_url = f"{ANIMESONLINE_BASE}/episodio/{base_name}-episodio-{episode}/"

    # Method 1: yt-dlp on the full episode page
    if YT_DLP_BIN and shutil.which(YT_DLP_BIN):
        try:
            result = subprocess.run(
                [YT_DLP_BIN, "--no-warnings", "--referer", ANIMESONLINE_BASE,
                 "--get-url", "--extractor-args", "generic:no-playlist",
                 ep_url],
                capture_output=True, text=True, timeout=30
            )
            if result.returncode == 0:
                urls = [l.strip() for l in result.stdout.split('\n')
                       if l.strip().startswith('http')]
                if urls:
                    return urls[0]
        except (subprocess.TimeoutExpired, OSError):
            pass

    # Method 2: Fetch page, find Blogger iframe, try yt-dlp on it
    session = get_session()
    try:
        r = http_get(session, ep_url)
    except Exception:
        return None
    if r.status_code != 200:
        return None

    html = r.text

    # Try each Blogger iframe URL
    blogger_urls = re.findall(
        r'src=["\'](https://www\.blogger\.com/video\.g\?token=[^"\']+)["\']', html
    )

    for b_url in blogger_urls[:2]:
        # yt-dlp on Blogger URL
        if YT_DLP_BIN and shutil.which(YT_DLP_BIN):
            try:
                result = subprocess.run(
                    [YT_DLP_BIN, "--no-warnings", "--referer", ep_url,
                     "--get-url", b_url],
                    capture_output=True, text=True, timeout=30
                )
                if result.returncode == 0:
                    urls = [l.strip() for l in result.stdout.split('\n')
                           if l.strip().startswith('http')]
                    if urls:
                        return urls[0]
            except (subprocess.TimeoutExpired, OSError):
                pass

        # Direct approach: HEAD/GET with redirects
        for method in ['head', 'get']:
            try:
                fn = requests.head if method == 'head' else session.get
                r2 = fn(b_url, impersonate='chrome120', timeout=15,
                        allow_redirects=True, headers={'Referer': ep_url})
                final = r2.url
                if final != b_url and ('googlevideo' in final or
                                       '.mp4' in final or
                                       'googleusercontent' in final):
                    return final
            except Exception:
                pass

    # Method 3: Playwright headless browser extraction
    if HAS_PLAYWRIGHT:
        pw_url, pw_q = get_blogger_video_url_playwright(ep_url)
        if pw_url:
            return pw_url

    return None


def download_animesonline(anime_title, slug, episode, quality="best", output_dir=None, embed_subs=False):
    """Download a single episode from AnimesOnlineCC (fallback).

    Returns path to downloaded file or None.
    """
    out_dir = output_dir or DEFAULT_DOWNLOAD_DIR
    os.makedirs(out_dir, exist_ok=True)

    plex_name = f"{anime_title} - S01E{episode:02d}.mp4"
    out_path = os.path.join(out_dir, plex_name)

    if os.path.isfile(out_path):
        print(f"  ⏭️  Already exists: {out_path}")
        return out_path

    print(f"  🔍 Extracting video from AnimesOnlineCC...")
    video_url = get_animesonline_video_url(slug, episode)

    if not video_url:
        print(f"  ❌ Could not extract video URL from AnimesOnlineCC.")
        print(f"  💡 AnimesOnlineCC uses Blogger's JS-based player which requires a browser.")
        print(f"  💡 Use --source animefire instead (AnimeFire has a working direct API).")
        print(f"  💡 Example: anime-dl-br download \"{slug}\" {episode} --source animefire")
        return None

    print(f"  📥 Downloading...")

    if YT_DLP_BIN and shutil.which(YT_DLP_BIN):
        ytdl_cmd = [YT_DLP_BIN, "--no-warnings", "--output", out_path,
                    "--referer", ANIMESONLINE_BASE,
                    "--user-agent", USER_AGENT]
        if 'googlevideo' in video_url.lower():
            ytdl_cmd += ["--no-check-certificate"]
        if embed_subs:
            ytdl_cmd += ["--embed-subs", "--embed-metadata"]
            ytdl_cmd += ["--sub-langs", "all"]
        ytdl_cmd += [video_url]
        try:
            result = subprocess.run(
                ytdl_cmd,
                capture_output=True, text=True, timeout=600
            )
            if result.returncode == 0 and os.path.isfile(out_path) and os.path.getsize(out_path) > 0:
                size_mb = os.path.getsize(out_path) / (1024 * 1024)
                print(f"  ✅ Complete: {size_mb:.1f} MB")
                return out_path
        except (subprocess.TimeoutExpired, OSError) as e:
            print(f"  ⚠️  yt-dlp: {e}")

    # Fallback: requests
    sess = get_session()
    try:
        kwargs = {"stream": True, "timeout": 120}
        if 'googlevideo' in video_url.lower():
            kwargs["verify"] = False
        # Set Referer to the episode page (googlevideo CDN requires it)
        base_name = re.sub(r'-hd$', '', slug)
        ep_ref = f"{ANIMESONLINE_BASE}/episodio/{base_name}-episodio-{episode}/"
        kwargs["headers"] = {"Referer": ep_ref}
        video_r = http_get(sess, video_url, **kwargs)
        video_r.raise_for_status()
        total = int(video_r.headers.get('content-length', 0))
        downloaded = 0
        with open(out_path, 'wb') as f:
            for chunk in video_r.iter_content(chunk_size=8192):
                if chunk:
                    f.write(chunk)
                    downloaded += len(chunk)
                    if total > 0:
                        pct = downloaded / total * 100
                        bar_len = 30
                        filled = int(bar_len * downloaded / total)
                        bar = '█' * filled + '░' * (bar_len - filled)
                        sys.stdout.write(f"\r    [{bar}] {pct:.0f}%")
                        sys.stdout.flush()
        print()
        if os.path.isfile(out_path) and os.path.getsize(out_path) > 0:
            size_mb = os.path.getsize(out_path) / (1024 * 1024)
            print(f"  ✅ Complete: {size_mb:.1f} MB")
            return out_path
    except Exception as e:
        print(f"  ❌ Download failed: {e}")
        if os.path.isfile(out_path):
            os.remove(out_path)

    return None


