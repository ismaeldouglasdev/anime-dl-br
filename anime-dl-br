# ── Title cleanup ─────────────────────────────────────────────────

def clean_title(title):
    """Decode HTML entities and strip common suffixes for cleaner display."""
    title = html.unescape(title).strip()
    return title


# ── Session helpers ───────────────────────────────────────────────

def get_session():
    """Create a session with Cloudflare bypass (curl_cffi or cloudscraper)."""
    if USE_CURL_CFFI:
        return requests.Session()
    return cloudscraper.create_scraper()

def http_get(session, url, **kwargs):
    """GET with impersonation/headers matching existing anime-dl pattern."""
    kwargs.setdefault('impersonate' if USE_CURL_CFFI else 'headers',
                     'chrome120' if USE_CURL_CFFI else {'User-Agent': USER_AGENT})
    kwargs.setdefault('timeout', 30)
    return session.get(url, **kwargs)


