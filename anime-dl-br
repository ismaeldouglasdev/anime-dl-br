    sp.add_argument("--source", choices=["animefire", "animesonline"],
                    default="animefire", help="Source (default: animefire)")
    sp.add_argument("--quality", "-q", choices=["best", "1080p", "720p", "480p", "360p"],
                    default="best", help="Quality (default: best)")
    sp.add_argument("--dir", "-d", default=None,
                    help=f"Output dir (default: {DEFAULT_DOWNLOAD_DIR})")
    sp.add_argument("--lang", default="pt-BR",
                    help="Language (default: pt-BR)")
    sp.add_argument("--embed-subs", action="store_true",
                    help="Embed subtitles into video (yt-dlp --embed-subs)")
    sp.add_argument("--no-track", action="store_true",
                    help="Skip GoAnime DB update")

    # ── Watch ──
    sp = subparsers.add_parser("watch", help="Play downloaded episode with mpv")
    sp.add_argument("title", help="Anime name (as in download dir)")
    sp.add_argument("episode", nargs="?", type=int, help="Episode number (default: list)")
    sp.add_argument("--player", "-p", default=None,
                    help="Player command (default: mpv)")
    sp.add_argument("--dir", "-d", default=None,
                    help=f"Download dir (default: {DEFAULT_DOWNLOAD_DIR})")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return

    # ══════════════════════════════════════════════════════════════
    #  SEARCH
    # ══════════════════════════════════════════════════════════════
    if args.command == "search":
        query = " ".join(args.query)

        actual_source = args.source
        if args.source == "animefire":
            results = search_animefire(query)
            if not results:
                # AnimeFire search endpoint may be unavailable; try animesonline as fallback
                results = search_animesonline(query)
                if results:
                    actual_source = "animesonline"
        else:
            results = search_animesonline(query)

        if args.json:
            out = [{"slug": r["slug"], "title": r["title"], "source": actual_source} for r in results]
            print(json.dumps(out))
            return

        if not results:
            print(f"🔍 Searching '{query}' on {args.source}...")
            print("❌ No results found")
            return

        print(f"🔍 Searching '{query}' on {args.source}...")
        print(f"\n📺 {len(results)} result(s):")
        print(f"{'#':<4} {'Slug':<55} {'Title':<60}")
        print("-" * 120)
        for i, r in enumerate(results, 1):
            print(f"{i:<4} {r['slug'][:53]:<55} {r['title'][:58]:<60}")

        print(f"\n💡 Use: anime-dl-br episodes <slug> --source {actual_source}")

        # When results came from animesonline (fallback or user-specified),
        # show likely AnimeFire slugs too
        if actual_source == "animesonline":
            print(f"\nℹ️  For AnimeFire download, try these slug patterns:")
            for r in results[:3]:
                guess = r['slug'].replace('-hd', '').replace('-todos-os-episodios', '')
                # Common animefire slug patterns
                for suffix in ['-tv', '-hd', '']:
                    af_slug = f"{guess}{suffix}"
                    print(f"     {af_slug:<45} --source animefire")
            print(f"   Or just use: anime-dl-br download \"{query}\" <ep> --source animefire")

    # ══════════════════════════════════════════════════════════════
    #  EPISODES
    # ══════════════════════════════════════════════════════════════
    elif args.command == "episodes":
        info = (get_animefire_episodes(args.slug) if args.source == "animefire"
                else get_animesonline_episodes(args.slug))

        if not info["episodes"]:
            if args.json:
                print(json.dumps({"title": info["title"], "episodes": [], "total_count": 0}))
                return
            print(f"📋 Getting episodes for '{args.slug}' on {args.source}...")
            print("❌ No episodes found")
            print("  💡 Verify the slug. Use 'search' first.")
            return

        title = info["title"]
        eps = info["episodes"]
        total = info["total_count"]

        if args.json:
            print(json.dumps({"title": title, "episodes": eps, "total_count": total}))
            return

        print(f"\n📺 {title}")
        print(f"🎬 Total episodes: {total}\n")

        for i in range(0, len(eps), 20):
            group = eps[i:i+20]
            nums = [str(e['num']) for e in group]
            if len(nums) > 1:
                print(f"  Episodes {group[0]['num']}-{group[-1]['num']}: ", end="")
            else:
                print(f"  Episode {nums[0]}: ", end="")
            print(" ".join(nums))

        print(f"\n💡 Use: anime-dl-br download \"{title}\" <ep> --source {args.source}")

    # ══════════════════════════════════════════════════════════════
    #  DOWNLOAD
    # ══════════════════════════════════════════════════════════════
    elif args.command == "download":
        title = args.title
        output_dir = args.dir if args.dir else DEFAULT_DOWNLOAD_DIR
        os.makedirs(output_dir, exist_ok=True)

        # Resolve slug and title
        slug, resolved_title = resolve_anime(args.source, title)
        if slug:
            title = resolved_title
        else:
            # Use the title as-is — it might be a direct slug or name
            slug = title.lower().replace(' ', '-')

        # Build episode list
        episodes_to_dl = []

        if args.all:
            info = (get_animefire_episodes(slug) if args.source == "animefire"
                    else get_animesonline_episodes(slug))
            if not info["episodes"]:
                print(f"❌ No episodes found for '{title}'")
                return
            episodes_to_dl = [e["num"] for e in info["episodes"]]
            if args.max > 0:
                episodes_to_dl = episodes_to_dl[:args.max]
                print(f"📥 Downloading first {args.max} of {info['total_count']} episodes of '{title}'")
            else:
                print(f"📥 Downloading ALL {len(episodes_to_dl)} episodes of '{title}'")

        elif args.range:
            parts = args.range.split('-')
            start = int(parts[0])
            end = int(parts[1]) if len(parts) > 1 else start
            episodes_to_dl = list(range(start, end + 1))
            print(f"📥 Downloading episodes {start}-{end} of '{title}'")

        elif args.episode:
            episodes_to_dl = [args.episode]
            print(f"📥 Downloading episode {args.episode} of '{title}'")

        else:
            print("❌ Specify an episode number, --range, or --all")
            return

        print(f"   Source: {args.source} | Quality: {args.quality}")
        print(f"   Output: {output_dir}\n")

        success_count = 0
        for ep in episodes_to_dl:
            print(f"{'='*60}")
            print(f"  📺 Episode {ep}")
            print(f"{'='*60}")

            if args.source == "animefire":
                filepath = download_animefire(
                    title, slug, ep, quality=args.quality,
                    output_dir=output_dir, embed_subs=args.embed_subs
                )
            else:
                filepath = download_animesonline(
                    title, slug, ep, quality=args.quality,
                    output_dir=output_dir, embed_subs=args.embed_subs
                )

            if filepath:
                success_count += 1
                if not args.no_track:
                    update_progress_db(title, ep, filepath)
            else:
                print(f"  ❌ Failed to download episode {ep}")

            print()

        if success_count > 0:
            print(f"✅ Downloaded {success_count}/{len(episodes_to_dl)} episodes")
            dir_files = [f for f in os.listdir(output_dir)
                        if f.endswith(('.mp4', '.mkv'))]
            print(f"   📁 {output_dir}/ ({len(dir_files)} files)")

            # Ask to watch the last downloaded episode (single episode mode)
            if len(episodes_to_dl) == 1:
                try:
                    resp = input(f"\n  ▶️  Watch now? [y/N]: ").strip().lower()
                    if resp in ('y', 'yes', 's', 'sim'):
                        print()
                        cmd_watch(title, episode=episodes_to_dl[0], download_dir=output_dir)
                except (EOFError, KeyboardInterrupt):
                    pass
        else:
            print(f"❌ No episodes were downloaded.")
            sys.exit(1)

    # ══════════════════════════════════════════════════════════════
    #  WATCH
    # ══════════════════════════════════════════════════════════════
    elif args.command == "watch":
        cmd_watch(args.title, episode=args.episode,
                  player=args.player, download_dir=args.dir)

    else:
        parser.print_help()


if __name__ == "__main__":
    main()
