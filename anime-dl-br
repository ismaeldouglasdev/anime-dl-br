        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  anime-dl-br search "jujutsu kaisen"
  anime-dl-br search "naruto" --source animesonline
  anime-dl-br episodes jujutsu-kaisen-tv-todos-os-episodios
