# ═══════════════════════════════════════════════════════════════════

def resolve_animefire_slug(query):
    """Try to find a valid AnimeFire slug by testing common patterns.

    AnimeFire's search endpoint is broken, so we probe known URL patterns.
    Returns (slug, title) or (None, None).
    """
    base = query.lower().strip()
    # Normalize: remove parens, collapse spaces, replace spaces with hyphens
    base = re.sub(r'[()]', '', base)
    base = re.sub(r'\s+', '-', base.strip())
    base = re.sub(r'-+', '-', base)

    session = get_session()
    # Order by preference: non-dubbed > subbed > dubbed
    # -tv and -hd are usually the original Japanese with subs
    patterns = [
        f"{base}-tv-todos-os-episodios",    # Best: original with subs, full listing
        f"{base}-hd-todos-os-episodios",
        f"{base}-legendado-todos-os-episodios",  # Explicitly subbed
        f"{base}-tv",
        f"{base}-hd",
        f"{base}-todos-os-episodios",        # Generic full listing
        f"{base}-dublado-todos-os-episodios",  # Dubbed (Portuguese) — lowest priority
        f"{base}-dublado",
        f"{base}",                            # Base slug last
    ]

    to_test = []
    seen = set()
    for p in patterns:
        if p not in seen:
            seen.add(p)
            to_test.append(p)

    for slug_candidate in to_test:
        # Try without trailing slash first (AnimeFire returns 404 with /)
        for url in [f"{ANIMEFIRE_BASE}/animes/{slug_candidate}",
                    f"{ANIMEFIRE_BASE}/animes/{slug_candidate}/"]:
            try:
                r = http_get(session, url, timeout=10)
                if r.status_code == 200:
                    h1 = re.search(r'<h1[^>]*>([^<]+)</h1>', r.text)
                    title = h1.group(1).strip() if h1 else slug_candidate.replace('-', ' ').title()
                    # Clean up episode-page H1 (e.g. "Jujutsu Kaisen (TV) - Episódio 1")
                    title = re.sub(r'\s*[-–—]\s*Epis[óo]dio\s+\d+.*$', '', title).strip()
                    title = re.sub(r'\s*[-–—]\s*Epis[óo]dio\s+[Úú]nico.*$', '', title).strip()
                    if not title:
                        title = slug_candidate.replace('-', ' ').title()
                    return slug_candidate, title
            except Exception:
                continue

    return None, None


def resolve_anime(source, query):
    """Search for an anime and return (slug, title) of best match."""
    if source == "animefire":
        results = search_animefire(query)
        if not results:
            # Search endpoint broken — try common URL patterns
            return resolve_animefire_slug(query)
    else:
        results = search_animesonline(query)

    if not results:
        return None, None

    # Exact match first
    q = query.lower()
    for r in results:
        if r["title"].lower() == q or r["slug"].lower() == q:
            return r["slug"], r["title"]

    # First result
    return results[0]["slug"], results[0]["title"]


