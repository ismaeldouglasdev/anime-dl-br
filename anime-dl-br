  anime-dl-br watch "Jujutsu Kaisen"          # list and pick episode
  anime-dl-br watch "Jujutsu Kaisen" 2 --player vlc
        """
    )

    subparsers = parser.add_subparsers(dest="command", help="Command")

    # ── Search ──
    sp = subparsers.add_parser("search", help="Search anime on BR sources")
    sp.add_argument("query", nargs="+", help="Anime name")
    sp.add_argument("--source", choices=["animefire", "animesonline"],
                    default="animefire", help="Source (default: animefire)")
    sp.add_argument("--json", action="store_true", help="JSON output for scripting")

    # ── Episodes ──
    sp = subparsers.add_parser("episodes", help="List episodes")
    sp.add_argument("slug", help="Anime slug from search results")
    sp.add_argument("--source", choices=["animefire", "animesonline"],
                    default="animefire", help="Source (default: animefire)")
    sp.add_argument("--json", action="store_true", help="JSON output for scripting")

    # ── Download ──
    sp = subparsers.add_parser("download", help="Download episode(s)")
    sp.add_argument("title", help="Anime name or slug")
    sp.add_argument("episode", nargs="?", type=int, help="Episode number")
    sp.add_argument("--range", "-r", help="Episode range (e.g. 1-12)")
    sp.add_argument("--all", "-a", action="store_true", help="Download all episodes")
